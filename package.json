{
  "name": "@goboldlyforward/turntable",
  "version": "2.0.0",
  "description": "Frame-flipping image slider driven by pointer, scroll, autorotate, or a range input. Zero dependencies.",
  "type": "module",
  "main": "./dist/turntable.cjs",
  "module": "./dist/turntable.js",
  "browser": "./dist/turntable.iife.js",
  "exports": {
    ".": {
      "import": "./dist/turntable.js",
      "require": "./dist/turntable.cjs",
      "default": "./dist/turntable.js"
    },
    "./css": "./dist/turntable.css"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "node build.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm test && npm run build"
  },
  "keywords": [
    "turntable",
    "flipbook",
    "image-slider",
    "scrubber",
    "pointer-events",
    "vanilla-js"
  ],
  "author": "Go Boldly Forward",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GoBoldlyForward/turntable.git"
  },
  "bugs": {
    "url": "https://github.com/GoBoldlyForward/turntable/issues"
  },
  "homepage": "https://goboldlyforward.github.io/turntable/",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "jsdom": "^25.0.0",
    "vitest": "^2.1.0"
  }
}
